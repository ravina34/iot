<head>
  <title>Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

<nav class="bg-blue-600 text-white p-4 flex justify-between">

<h1 class="text-2xl font-bold">
SISTec IoT Application 2026
</h1>

<h2>
Welcome <%= user.name %>
</h2>

</nav>

<div class="p-6">
<!-- SECTION 1 -->

<div class="grid grid-cols-2 gap-6">

<div class="bg-white p-6 rounded shadow text-center">
<h2 class="text-xl font-bold mb-4">Temperature</h2>

<h1 class="text-5xl font-bold text-red-500">
<%= latest ? latest.temperature : 0 %> °C
</h1>

<p class="mt-4">
<%= latest ? latest.time : '' %>
</p>

<p>
<%= latest ? latest.date : '' %>
</p>

</div>
<div class="bg-white p-6 rounded shadow text-center">
<h2 class="text-xl font-bold mb-4">Humidity</h2>

<h1 class="text-5xl font-bold text-blue-500">
<%= latest ? latest.humidity : 0 %> %
</h1>

<p class="mt-4">
<%= latest ? latest.time : '' %>
</p>

<p>
<%= latest ? latest.date : '' %>
</p>

</div>

</div>
<!-- SECTION 2 -->

<div class="bg-white p-6 rounded shadow mt-8">

<h2 class="text-2xl font-bold mb-4">
LCD Display Text
</h2>

<form action="/save-lcd" method="POST">

<textarea
name="text"
maxlength="16"
class="border w-full p-4 text-2xl"
rows="3"><%= lcdText %></textarea>

<button class="bg-green-500 text-white px-6 py-2 rounded mt-4">
Save Text
</button>

</form>

</div>
<!-- SECTION 3 -->

<div class="bg-white p-6 rounded shadow mt-8 overflow-auto">

<h2 class="text-2xl font-bold mb-4">
Sensor Records
</h2>

<table class="w-full border">

<tr class="bg-gray-200">
<th class="border p-2">#</th>
<th class="border p-2">Temperature</th>
<th class="border p-2">Humidity</th>
<th class="border p-2">Time</th>
<th class="border p-2">Date</th>
<th class="border p-2">Action</th>
</tr>

<% rows.forEach((row,index)=>{ %>
    <tr>
<td class="border p-2"><%= index+1 %></td>
<td class="border p-2"><%= row.temperature %> °C</td>
<td class="border p-2"><%= row.humidity %> %</td>
<td class="border p-2"><%= row.time %></td>
<td class="border p-2"><%= row.date %></td>
<td class="border p-2">
<a href="/delete/<%= row.id %>"
class="bg-red-500 text-white px-3 py-1 rounded">
Delete
</a>
</td>
</tr>

<% }) %>

</table>

</div>
</div>

</body>
</html>